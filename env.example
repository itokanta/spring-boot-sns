# ===========================================
# Spring Boot SNS - 環境変数テンプレート
# ===========================================
# 使用方法: 
# 1. cp env.example .env
# 2. .envファイル内の値を適切に設定してください

# ===========================================
# データベース接続情報
# ===========================================
# PostgreSQL接続URL
DB_URL=your_db_URL

# データベースユーザー名
DB_USERNAME=your_db_username

# データベースパスワード（セキュリティのため実際のパスワードに変更してください）
DB_PASSWORD=your_secure_password

# ===========================================
# アプリケーション設定
# ===========================================
# Webサーバーポート
SERVER_PORT=8080

# ===========================================
# セキュリティについて
# ===========================================
# ⚠️  重要: 本番環境では必ず強力なパスワードを使用してください
# ⚠️  .envファイルは.gitignoreに含まれており、Gitにコミットされません
# ⚠️  .envファイルを他人と共有しないでください